# Environment variables
# Copy this file to .env and fill in your Revolut sandbox credentials

# Server port
PORT=5177

# Revolut API Configuration (Sandbox)
REVOLUT_API_URL=https://sandbox-merchant.revolut.com
REVOLUT_API_PUBLIC_KEY=pk_your_sandbox_public_key_here
REVOLUT_API_SECRET_KEY=sk_your_sandbox_secret_key_here

# Webhook secret (for verifying webhook signatures)
REVOLUT_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# Static files directory (for production)
STATIC_DIR=../client/dist
